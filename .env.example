# .env.example
# Copy this file to .env and fill in your values.
# The application loads this file automatically via python-dotenv.

# ── Required ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ── Optional overrides (defaults are set in config.py) ────────────────────────
# LLM_MODEL=gpt-4o            # or gpt-3.5-turbo for lower cost
# EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# INGESTION_WORKERS=6
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=150
# TOP_K_BM25=20
# TOP_K_FAISS=20
# TOP_K_FINAL=10
# LLM_CONCURRENCY=5
